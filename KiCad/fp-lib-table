(fp_lib_table
	(version 7)
	(lib (name "Cherry_MX") (type "KiCad") (uri "${KICAD10_3RD_PARTY}/footprints/com_github_perigoso_keyswitch-kicad-library/Switch_Keyboard_Cherry_MX.pretty") (options "") (descr "Cherry MX keyswitch PCB footprints (perigoso/keyswitch-kicad-library, installed via PCM)"))
	(lib (name "Cherry_MX_Custom") (type "KiCad") (uri "${KIPRJMOD}/Cherry_MX_Custom.pretty") (options "") (descr "Custom Cherry MX Enter/Space footprints with hand-built leveling-kit stabilizer holes (Mouser 540-G99-0742 + 540-G99-0226), no official library equivalent exists"))
	(lib (name "MountingHole_Custom") (type "KiCad") (uri "${KIPRJMOD}/MountingHole_Custom.pretty") (options "") (descr "Materialized grounded M3 mounting hole (3.048mm drill / 4.064mm pad) matching the project's exact original geometry - no official KiCad MountingHole variant offers a pad this small at this drill size"))
	(lib (name "Conn_RCA_Custom") (type "KiCad") (uri "${KIPRJMOD}/Conn_RCA_Custom.pretty") (options "") (descr "RCA phono jack (Same Sky/CUI RCJ-014, Mouser 490-RCJ-014) - no official KiCad RCA jack footprint exists in any installed library. Geometry sourced from the manufacturer-verified SnapEDA footprint (matches the official RCJ-01 series datasheet dimensions exactly, more accurately than the project's own hand-drawn original), includes the manufacturer's STEP 3D model"))
	(lib (name "Conn_DCJack_Custom") (type "KiCad") (uri "${KIPRJMOD}/Conn_DCJack_Custom.pretty") (options "") (descr "2mm DC power jack (Kycon KLDX-0202-A, Mouser 806-KLDX-0202-A) - the only official KiCad BarrelJack footprint for this part family (BarrelJack_Kycon_KLDX-0202-xC_Horizontal) is for the crimped-lead '-xC' sibling, not this straight-lead '-A' part. Geometry sourced from the manufacturer's own KiCad library export (SamacSys/Ultra Librarian), includes the manufacturer's STEP 3D model"))
	(lib (name "Conn_FrictionLock_Custom") (type "KiCad") (uri "${KIPRJMOD}/Conn_FrictionLock_Custom.pretty") (options "") (descr "8-position friction-lock header, 2.54mm pitch (TE Connectivity/AMP 640456-8, MTA-100 series, Mouser 571-6404568) - no official KiCad footprint exists for this shrouded friction-lock part. Geometry sourced from the manufacturer's own KiCad library export (SamacSys/Ultra Librarian), includes the manufacturer's STEP 3D model"))
	(lib (name "Conn_DIN_Custom") (type "KiCad") (uri "${KIPRJMOD}/Conn_DIN_Custom.pretty") (options "") (descr "8-pin right-angle DIN jack with front shield (Same Sky/CUI SDF-80J, Mouser 490-SDF-80J) - no official KiCad footprint exists for any round DIN connector (only rectangular DIN41612 card-edge connectors are in the official library). Geometry sourced from the manufacturer's own KiCad library export (SamacSys/Ultra Librarian), includes the manufacturer's STEP 3D model"))
	(lib (name "DCDC_Custom") (type "KiCad") (uri "${KIPRJMOD}/DCDC_Custom.pretty") (options "") (descr "3W isolated DC-DC converter, dual +/-12V output, SIP8 (XP Power IZ0512S, Mouser 209-IZ0512S) - pad layout verified pad-for-pad against the manufacturer's datasheet mechanical drawing. No manufacturer or official KiCad 3D model exists for this exact part; 3D model is the manufacturer's own STEP model for sibling part IA0512S (same SIP potted-module family), anisotropically scaled to the IZ0512S's real datasheet body dimensions - an approximation, not an exact manufacturer model"))
	(lib (name "Speaker_Custom") (type "KiCad") (uri "${KIPRJMOD}/Speaker_Custom.pretty") (options "") (descr "12mm magnetic transducer speaker (PUI Audio AT-1224-TWT-R, Mouser 665-AT-1224TWTR) - no official KiCad footprint exists for this part. Geometry sourced from the manufacturer's own KiCad library export (SamacSys/Ultra Librarian), verified against the manufacturer datasheet mechanical drawing, includes the manufacturer's STEP 3D model"))
)
