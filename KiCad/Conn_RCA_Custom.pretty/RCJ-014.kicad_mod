(footprint "RCJ-014"
	(layer "F.Cu")
	(descr "RCA phono jack, right-angle, yellow insulator (Same Sky/CUI RCJ-014, Mouser 490-RCJ-014). Pad geometry sourced from the manufacturer-verified SnapEDA footprint (drill sizes and pad spacing match the official Same Sky RCJ-01 series datasheet recommended PCB layout exactly: 1.70mm signal drill, 2.60mm x3 ground drill, 10.00mm ground-to-ground span, 4.50mm signal-to-odd-ground spacing) rather than the project's original hand-drawn approximation, which was off by 0.58mm on the signal-to-odd-ground dimension.")
	(tags "RCA phono jack connector")
	(property "Reference" "REF**"
		(at -5.5 -5.8 0)
		(layer "F.SilkS")
		(hide yes)
		(effects
			(font
				(size 1.0 1.0)
				(thickness 0.15)
			)
		)
	)
	(property "Value" "RCJ-014"
		(at -1.4 5.5 0)
		(layer "F.Fab")
		(hide yes)
		(effects
			(font
				(size 1.0 1.0)
				(thickness 0.15)
			)
		)
	)
	(property "Datasheet" "https://www.sameskydevices.com/product/resource/rcj-01.pdf"
		(at 0 0 0)
		(layer "F.Fab")
		(hide yes)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
	)
	(property "Description" ""
		(at 0 0 0)
		(layer "F.Fab")
		(hide yes)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
	)
	(attr through_hole)
	(duplicate_pad_numbers_are_jumpers no)
	(fp_line (start -0.70 -4.15) (end -8.70 -4.15) (stroke (width 0.127) (type solid)) (layer "F.Fab"))
	(fp_line (start -8.70 -4.15) (end -8.70 4.15) (stroke (width 0.127) (type solid)) (layer "F.Fab"))
