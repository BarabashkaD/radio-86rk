	(pad "1" thru_hole circle (at 4.5 0) (size 2.55 2.55) (drill 1.7) (layers "*.Cu" "*.Mask") (remove_unused_layers no))
	(pad "2" thru_hole circle (at 0 0) (size 3.616 3.616) (drill 2.6) (layers "*.Cu" "*.Mask") (remove_unused_layers no))
	(pad "2" thru_hole circle (at 4.5 -5.0) (size 3.616 3.616) (drill 2.6) (layers "*.Cu" "*.Mask") (remove_unused_layers no))
	(pad "2" thru_hole circle (at 4.5 5.0) (size 3.616 3.616) (drill 2.6) (layers "*.Cu" "*.Mask") (remove_unused_layers no))
