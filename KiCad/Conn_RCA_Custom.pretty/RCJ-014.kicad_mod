	(fp_line (start -8.95 -4.4) (end -8.95 4.4) (stroke (width 0.05) (type solid)) (layer "F.CrtYd"))
	(fp_line (start -8.95 4.4) (end -0.95 4.4) (stroke (width 0.05) (type solid)) (layer "F.CrtYd"))
