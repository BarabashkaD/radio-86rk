(footprint "AT-1224-TWT-R"
	(layer "F.Cu")
	(descr "12mm magnetic transducer speaker (PUI Audio AT-1224-TWT-R, Mouser 665-AT-1224TWTR). No official KiCad footprint exists for this part. Geometry sourced from the manufacturer's own KiCad library export (SamacSys/Ultra Librarian), verified against the manufacturer datasheet mechanical drawing (Ø12mm body, 6.5mm pin pitch, 2x0.6mm pin holes). Includes the manufacturer's STEP 3D model.")
	(tags "Speaker Magnetic Transducer AT-1224-TWT-R PUI Audio")
	(property "Reference" "REF**"
		(at 0 -4.2 0)
		(layer "F.SilkS")
		(hide yes)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.254)
			)
		)
	)
	(property "Value" "AT-1224-TWT-R"
		(at 0 10.5 0)
		(layer "F.Fab")
		(hide yes)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.254)
			)
		)
	)
	(property "Datasheet" "https://puiaudio.com/file/specs-AT-1224-TWT-R.pdf"
		(at 0 0 0)
		(layer "F.Fab")
		(hide yes)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
	)
	(property "Description" ""
		(at 0 0 0)
		(layer "F.Fab")
		(hide yes)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
	)
	(attr through_hole)
	(duplicate_pad_numbers_are_jumpers no)
	(fp_line (start -7 -3.75) (end 7 -3.75) (stroke (width 0.1) (type solid)) (layer "F.CrtYd"))
	(fp_line (start 7 -3.75) (end 7 10.25) (stroke (width 0.1) (type solid)) (layer "F.CrtYd"))
	(fp_line (start 7 10.25) (end -7 10.25) (stroke (width 0.1) (type solid)) (layer "F.CrtYd"))
	(fp_line (start -7 10.25) (end -7 -3.75) (stroke (width 0.1) (type solid)) (layer "F.CrtYd"))
	(fp_circle (center 0 3.25) (end 0 -2.75) (stroke (width 0.1) (type solid)) (fill no) (layer "F.Fab"))
	(fp_circle (center 0 3.25) (end 0 -2.75) (stroke (width 0.2) (type solid)) (fill no) (layer "F.SilkS"))
	(pad "1" thru_hole rect (at 0 0) (size 1.3 1.3) (drill 0.8) (layers "*.Cu" "*.Mask"))
	(pad "2" thru_hole circle (at 0 6.5) (size 1.3 1.3) (drill 0.8) (layers "*.Cu" "*.Mask"))
	(embedded_fonts no)
	(model "${KIPRJMOD}/Speaker_Custom.pretty/AT-1224-TWT-R.step"
		(offset (xyz 0 0 0))
		(scale (xyz 1 1 1))
		(rotate (xyz 0 0 0))
	)
)
