	(fp_line (start 5.35 12.7) (end -15.35 12.7) (stroke (width 0.1) (type solid)) (layer "F.SilkS"))
	(fp_line (start -15.35 12.7) (end -15.35 -6.3) (stroke (width 0.1) (type solid)) (layer "F.SilkS"))
	(fp_line (start -16.35 -7.3) (end 7.1 -7.3) (stroke (width 0.1) (type solid)) (layer "F.CrtYd"))
	(fp_line (start 7.1 -7.3) (end 7.1 13.7) (stroke (width 0.1) (type solid)) (layer "F.CrtYd"))
	(fp_line (start 7.1 13.7) (end -16.35 13.7) (stroke (width 0.1) (type solid)) (layer "F.CrtYd"))
	(fp_line (start -16.35 13.7) (end -16.35 -7.3) (stroke (width 0.1) (type solid)) (layer "F.CrtYd"))
	(fp_circle (center 6 -0.6) (end 6 -0.5) (stroke (width 0.2) (type solid)) (fill no) (layer "F.SilkS"))
	(pad "1" thru_hole circle (at 0 0) (size 1.95 1.95) (drill 1.3) (layers "*.Cu" "*.Mask"))
	(pad "2" thru_hole circle (at -5 0) (size 1.95 1.95) (drill 1.3) (layers "*.Cu" "*.Mask"))
	(pad "3" thru_hole circle (at -10 0) (size 1.95 1.95) (drill 1.3) (layers "*.Cu" "*.Mask"))
