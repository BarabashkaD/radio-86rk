(footprint "SDF-80J"
	(layer "F.Cu")
	(descr "8-pin right-angle DIN jack with front shield (Same Sky/CUI SDF-80J, Mouser 490-SDF-80J). No official KiCad footprint exists for any round DIN connector (only DIN41612 rectangular card-edge connectors are in the official library). Geometry sourced from the manufacturer's own KiCad library export (SamacSys/Ultra Librarian). Pad numbering follows the project's schematic symbol convention: pins 1-8 are the signal contacts; the two large mechanical pads (manufacturer's MH1/MH2) are labeled '~' matching the two unconnected mounting-leg pins already defined on the symbol; the two small mechanical pads (manufacturer's MH3/MH4) are labeled '0' matching the symbol's two GND shield-tab pins. Includes the manufacturer's STEP 3D model.")
	(tags "Connector DIN SDF-80J CUI Same Sky")
	(property "Reference" "REF**"
		(at -4.625 3.2 0)
		(layer "F.SilkS")
		(hide yes)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.254)
			)
		)
	)
	(property "Value" "SDF-80J"
		(at -4.625 3.2 0)
		(layer "F.Fab")
		(hide yes)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.254)
			)
		)
	)
	(property "Datasheet" "https://www.mouser.com/datasheet/2/670/sdf_j-1779185.pdf"
		(at 0 0 0)
		(layer "F.Fab")
		(hide yes)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
	)
	(property "Description" ""
		(at 0 0 0)
		(layer "F.Fab")
		(hide yes)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
	)
	(attr through_hole)
	(duplicate_pad_numbers_are_jumpers no)
	(fp_line (start -15.35 -6.3) (end 5.35 -6.3) (stroke (width 0.2) (type solid)) (layer "F.Fab"))
